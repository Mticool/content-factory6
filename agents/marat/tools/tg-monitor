#!/bin/bash
# Мониторинг Telegram каналов для новостей маркетплейсов

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="$SCRIPT_DIR/../monitoring/marketplace-news"
CHANNELS_FILE="$SCRIPT_DIR/../monitoring/telegram-channels.txt"

TODAY=$(date +%Y-%m-%d)

# Проверка авторизации
if [ ! -d "$HOME/.openclaw/telegram-sessions" ]; then
    echo "❌ Telegram не авторизован. Запусти сначала авторизацию."
    echo "Попробуй: ./tools/tg-read @ozonmarketplace 5"
    exit 1
fi

echo "📱 Monitoring Telegram channels..."

# Читаем список каналов
CHANNELS=(
    "@ozonmarketplace"
    "@mkeeper"
    "@vladlen_strokan"
    "@ozon_seller"
    "@wb_sellers"
)

mkdir -p "$OUTPUT_DIR/telegram"

# Для каждого канала - берём последние 10 постов
for channel in "${CHANNELS[@]}"; do
    echo "Reading $channel..."
    
    OUTPUT_FILE="$OUTPUT_DIR/telegram/${channel#@}-${TODAY}.json"
    
    # Используем tg-read для получения постов
    ./tools/tg-read "$channel" 10 0 > "$OUTPUT_FILE" 2>&1
    
    if [ $? -eq 0 ]; then
        echo "  ✅ Saved to $OUTPUT_FILE"
    else
        echo "  ⚠️ Failed to read $channel"
    fi
    
    # Пауза между запросами
    sleep 2
done

echo ""
echo "📊 Telegram monitoring complete!"
echo "Results in: $OUTPUT_DIR/telegram/"
echo ""
echo "Next: analyze with AI to extract critical changes"
